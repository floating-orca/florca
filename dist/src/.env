DEPLOYER_DATABASE_URL=postgres://postgres:mysecretpassword@127.0.0.1/deployer
ENGINE_DATABASE_URL=postgres://postgres:mysecretpassword@127.0.0.1/engine

# Having Basic Auth enabled even in a local environment helps to identify requests that lack the authorization header
BASIC_AUTH_USERNAME=root
BASIC_AUTH_PASSWORD=hCM2ojfA.JdHis8xDhGW

# Via reverse proxy (HTTP)
DEPLOYER_URL=http://deployer.florca.localhost:8080
ENGINE_URL=http://engine.florca.localhost:8080

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# The region where AWS Lambda functions are going to be deployed
AWS_REGION=eu-central-1

# The ARN of the role that the Lambda function will assume when running
# AWS_ROLE=

# The URL which Knative functions will use to access the engine
# `172-17-0-1` referst to the IP address of the host machine in the Docker network
ENGINE_URL_FOR_ACCESS_FROM_KN=http://engine.172-17-0-1.sslip.io:8080
